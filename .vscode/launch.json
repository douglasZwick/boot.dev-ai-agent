{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug main.py (prompt for args)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "args": ["${input:cliArgs}", "-v"]
    }
  ],
  "inputs": [
    {
      "id": "cliArgs",
      "type": "promptString",
      "description": "Enter CLI arguments",
      "default": ""
    }
  ]
}
